{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mouse Wobbler",
  "version": "0.3.0",
  "identifier": "com.enverkaradede.mousewobbler",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Mouse Wobbler",
        "width": 420,
        "height": 685,
        "resizable": false,
        "visible": true,
        "center": true,
        "decorations": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
